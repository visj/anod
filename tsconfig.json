{
  "compilerOptions": {
    "composite": true,         // Required for project references
    "noEmit": true,
    "declaration": true,       // Generates .d.ts files for other packages
    "declarationMap": true,    // Maps types back to source files for IDE support
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "anod/*": ["./packages/anod/src"] // Optional: facilitates IDE auto-imports
    }
  },
  "references": [
    { "path": "./packages/anod" },
    { "path": "./packages/anod-list" }
  ]
}
